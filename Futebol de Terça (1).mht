<input id="cashAdjustAmount" placeholder="Ex: 100 (entrada) ou -50 (saída)" step="0.01" type="number">
</div>
<div class="form-group" style="flex:2;min-width:220px">
<label>Obs</label>
<input id="cashAdjustNote" placeholder="Ex: saldo anterior, troco, acerto..." type="text">
</div>
<button class="btn btn-primary" type="button">Aplicar ajuste</button>
</div><div class="small" style="margin-top:6px">Use valor positivo para entrada no caixa e negativo para saída. Não vincula a jogador.</div></div><div class="card fin-card fin-payment">
<h4>✅ Registrar pagamento</h4>
<div class="finance-row">
<div class="form-group" style="flex:1">
<label>Jogador</label>
<select id="payPlayer" disabled=""><option value="">Selecione...</option></select>
</div>
<div class="form-group">
<label>Valor (R$)</label>
<input id="payAmount" min="0" step="1" type="number" value="15">
</div>
</div>
<div class="finance-row" style="margin-top:8px">
<div class="form-group" style="flex:1">
<label>Obs (Pix, dinheiro, etc.)</label>
<input id="payNote" placeholder="Ex: Pix, fulano pagou pra ciclano" type="text">
</div>
<button class="btn btn-green">Salvar pagamento</button>
</div>
</div><div class="card fin-card fin-expense">
