<div class="small" id="financeSummary" style="margin-bottom:8px">
                <div class="kpi-row">
                    <div class="kpi-item">
                        <div class="kpi-label">Caixa</div>
                        <div class="kpi-value kpi-cash pos"><span class="mono">+ R$ 0,00</span></div>
                    </div>
                    <div class="kpi-item">
                        <div class="kpi-label">Total a receber</div>
                        <div class="kpi-value kpi-recv"><span class="mono">R$ 0,00</span></div>
                    </div>
