<option value="bola">Bola / material</option>
<option value="outros">Outros</option>
</select>
</div>
<div class="form-group">
<label>Valor (R$)</label>
<input id="expAmount" min="0" step="1" type="number" value="0">
</div>
</div>
<div class="finance-row" style="margin-top:8px">
